# Global
HOST_TZ=<PUT-HOST-TZ-HERE>

# Wazuh Version (all three images must match)
WAZUH_VERSION=4.14.6

# ── Wazuh Indexer ──────────────────────────────────────────────────────────────
WAZUH_INDEXER_JAVA_OPTS=<PUT-JAVA-OPTS-HERE>  # Eg: -Xms2g -Xmx2g
WAZUH_INDEXER_USERNAME=<PUT-INDEXER-USERNAME-HERE>
WAZUH_INDEXER_PASSWORD=<PUT-INDEXER-PASSWORD-HERE>

# ── Wazuh Manager ─────────────────────────────────────────────────────────────
WAZUH_AGENT_PORT=<PUT-WAZUH-AGENT-PORT-HERE>        # Agent-manager UDP (default: 1514)
WAZUH_ENROLLMENT_PORT=<PUT-WAZUH-ENROLLMENT-PORT-HERE>  # Agent enrollment TCP (default: 1515)
WAZUH_API_PORT=<PUT-WAZUH-API-PORT-HERE>             # REST API port (default: 55000)
WAZUH_API_USERNAME=<PUT-API-USERNAME-HERE>
WAZUH_API_PASSWORD=<PUT-API-PASSWORD-HERE>

# ── Wazuh Dashboard ───────────────────────────────────────────────────────────
WAZUH_DASHBOARD_PORT=<PUT-WAZUH-DASHBOARD-PORT-HERE>  # Host port for the web UI
WAZUH_DASHBOARD_USERNAME=<PUT-DASHBOARD-USERNAME-HERE>
WAZUH_DASHBOARD_PASSWORD=<PUT-DASHBOARD-PASSWORD-HERE>

# ── Mount Directories ─────────────────────────────────────────────────────────
# TLS Certificates (shared by all three services; generated via cert helper)
WAZUH_CERTS_MOUNT_DIR=<PUT-WAZUH-CERTS-MOUNT-DIR-HERE>
# Wazuh Indexer
WAZUH_INDEXER_DATA_MOUNT_DIR=<PUT-WAZUH-INDEXER-DATA-MOUNT-DIR-HERE>
# Wazuh Manager
WAZUH_MANAGER_CONFIG_MOUNT_DIR=<PUT-WAZUH-MANAGER-CONFIG-MOUNT-DIR-HERE>
WAZUH_MANAGER_LOGS_MOUNT_DIR=<PUT-WAZUH-MANAGER-LOGS-MOUNT-DIR-HERE>
WAZUH_MANAGER_QUEUE_MOUNT_DIR=<PUT-WAZUH-MANAGER-QUEUE-MOUNT-DIR-HERE>
WAZUH_MANAGER_DATA_MOUNT_DIR=<PUT-WAZUH-MANAGER-DATA-MOUNT-DIR-HERE>
